# NodeMaven proxy (default)
NODEMAVEN_PROXY_HOST=gate.nodemaven.com:8080
NODEMAVEN_PROXY_USER=
NODEMAVEN_PROXY_PASSWORD=

# Agent headless onboarding
NEXTBROWSER_USE_CASE=scrape
NEXTBROWSER_BROWSER=native
NEXTBROWSER_PROXY=nodemaven
NEXTBROWSER_AUTOMATION=browser_use
NEXTBROWSER_HEADLESS=true

# LLM inherits from agent — optional override
# NEXTBROWSER_LLM_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Multilogin X — https://documenter.getpostman.com/view/28533318/2s946h9Cv9
# Requires Multilogin X app/agent running (launcher on :45001)
MULTILOGIN_EMAIL=
MULTILOGIN_PASSWORD=
# Or paste automation token (recommended): GET /workspace/automation_token
MULTILOGIN_AUTOMATION_TOKEN=
# MULTILOGIN_TOKEN=
MULTILOGIN_FOLDER_ID=
MULTILOGIN_PROFILE_ID=
# Per-account: MULTILOGIN_PROFILE_SOCIAL_01=<uuid>
# MULTILOGIN_LAUNCHER_URL=https://launcher.mlx.yt:45001
# GOLOGIN_PROFILE_ACCT_01=

# Optional CAPTCHA
# NEXTBROWSER_CAPTCHA_ENABLED=false
# CAPTCHA_API_TOKEN=
